---
const links = [
  { name: 'من نحن', href: '#about' },
  { name: 'خدماتنا المخصصة', href: '#services' },
  { name: 'الأسئلة الشائعة', href: '#faq' },
  { name: 'تواصل معنا', href: '#contact' },
];
---

<header class="fixed top-0 left-0 w-full z-50 transition-all duration-300 px-6 py-4" id="main-header">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    
    <!-- Left: Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-8 h-8 bg-white/90 rounded-full shadow-lg shadow-white/20 relative flex items-center justify-center overflow-hidden border border-white/40">
        <!-- Wool-style texture/dot effect -->
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/felt.png')] opacity-20"></div>
        <div class="w-3 h-3 bg-ethereal-accent/40 rounded-full blur-[2px]"></div>
      </div>
      <span class="font-serif text-xl tracking-[0.1em] text-white/95 group-hover:text-white transition-colors">AETHEREAL</span>
    </a>

    <!-- Desktop Menu (Right) -->
    <nav class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a href={link.href} class="text-sm font-semibold text-white/80 hover:text-white transition-all hover:-translate-y-0.5">
          {link.name}
        </a>
      ))}
      <a href="#book" class="px-6 py-2.5 bg-white/10 hover:bg-white/20 border border-white/50 backdrop-blur-md text-white font-bold rounded-full transition-all duration-300 shadow-xl shadow-white/10 hover:shadow-white/20 transform hover:-translate-y-1 text-sm">
        احجز موعداً
      </a>
    </nav>

    <!-- Mobile Button -->
    <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2 bg-white/5 backdrop-blur-sm rounded-lg border border-white/10" aria-label="Menu">
      <span class="w-6 h-0.5 bg-white/90 rounded-full"></span>
      <span class="w-6 h-0.5 bg-white/90 rounded-full"></span>
      <span class="w-6 h-0.5 bg-white/90 rounded-full"></span>
    </button>
  </div>

  <!-- Mobile Overlay -->
  <div id="mobile-overlay" class="fixed inset-0 bg-ethereal-dark/95 backdrop-blur-xl z-[60] flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-all duration-300">
    <button id="close-menu-btn" class="absolute top-8 right-8 text-white/60 hover:text-white transition-colors">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    {links.map(link => (
      <a href={link.href} class="text-2xl font-bold text-white hover:text-ethereal-light transition-colors mobile-link">
        {link.name}
      </a>
    ))}
    <a href="#book" class="mt-4 px-8 py-3 bg-white/10 border border-white/40 text-white font-bold rounded-full mobile-link">
      احجز موعداً
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('close-menu-btn');
  const overlay = document.getElementById('mobile-overlay');
  const links = document.querySelectorAll('.mobile-link');

  // Change header background on scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header.classList.add('bg-ethereal-dark/40', 'backdrop-blur-lg', 'shadow-lg');
      header.classList.remove('py-4');
      header.classList.add('py-3');
    } else {
      header.classList.remove('bg-ethereal-dark/40', 'backdrop-blur-lg', 'shadow-lg');
      header.classList.remove('py-3');
      header.classList.add('py-4');
    }
  });

  // Toggle Menu
  const toggleMenu = (show) => {
    if (show) {
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      document.body.style.overflow = 'hidden';
    } else {
      overlay.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
    }
  };

  menuBtn?.addEventListener('click', () => toggleMenu(true));
  closeBtn?.addEventListener('click', () => toggleMenu(false));
  links.forEach(l => l.addEventListener('click', () => toggleMenu(false)));
</script>
