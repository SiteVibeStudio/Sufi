---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AETHEREAL | الصحة النفسية" description="رفع مستوى التميز الذهني في لندن.">
  
  <!-- Hero Section with Layered Fluffy Assets -->
  <section class="w-full relative min-h-[90vh] bg-ethereal-dark flex flex-col items-center pt-12 pb-48 text-center overflow-hidden">
    <!-- Texture Overlay for the dark fur feel -->
    <div class="absolute inset-0 z-0 bg-[url('/light_blue_fur.png')] bg-cover mix-blend-overlay opacity-30 pointer-events-none"></div>
    
    <!-- Floating Fluffy Balloon (Top Right) -->
    <img src="/f-balloon.png" alt="Fluffy Balloon" class="absolute top-12 right-4 md:right-24 w-48 md:w-64 h-auto z-10 animate-[float_6s_ease-in-out_infinite] pointer-events-none drop-shadow-2xl" />

    <!-- Random Floating Fluffy Clouds (Background) -->
    <img src="/f-cloud-dark.png" alt="Cloud" class="absolute top-32 -left-16 w-80 opacity-60 z-10 animate-[float_8s_ease-in-out_infinite_reverse] pointer-events-none" />

    <div class="relative z-30 w-full max-w-4xl px-4 flex flex-col items-center mt-8">
      <h1 class="font-serif text-3xl md:text-4xl tracking-[0.2em] text-white/90 mb-12 drop-shadow-lg">AETHEREAL</h1>
      
      <div class="relative z-30">
        <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6 leading-tight drop-shadow-xl max-w-2xl mx-auto">
          رفع مستوى التميز الذهني في لندن.
        </h2>
        <p class="text-base md:text-lg font-semibold text-white/90 max-w-lg mx-auto mb-8 drop-shadow-md">
          طريقتك الشخصي والتحويلي نحو المرونة يبدأ من علاج قليل من الدعم النفسي المتميزون المغتربون.
        </p>
        
        <button class="px-8 py-3 bg-white/10 hover:bg-white/20 border border-white/50 backdrop-blur-md text-white font-bold rounded-full transition-all duration-300 shadow-xl shadow-ethereal-dark/40 transform hover:-translate-y-1">
          حجز استشارة خاصة
        </button>
      </div>
    </div>

    <!-- The Fluffy Cloud Floor (Transitions to body) -->
    <div class="absolute bottom-0 left-0 right-0 z-20 flex justify-center items-end transform translate-y-1/4 pointer-events-none">
      <!-- Cluster of overlapping clouds -->
      <img src="/f-cloud-dark.png" alt="Cloud" class="w-1/2 max-w-[500px] object-contain -mr-20 z-10" />
      <img src="/f-cloud-light.png" alt="Cloud" class="w-1/2 max-w-[600px] object-contain mb-8 z-20 scale-125 origin-bottom" />
      <img src="/f-cloud-dark.png" alt="Cloud" class="w-1/3 max-w-[400px] object-contain -ml-20 mb-4 z-10" />
      <img src="/f-cloud-light.png" alt="Cloud" class="absolute right-0 bottom-0 w-1/4 max-w-[300px] object-contain translate-x-1/2 mb-12 z-30" />
    </div>
    
    <!-- Gradient Fade into next section -->
    <div class="absolute bottom-0 inset-x-0 h-48 bg-gradient-to-b from-transparent to-ethereal-light z-10"></div>
  </section>

  <!-- Main Body Content -->
  <div class="w-full bg-ethereal-light flex flex-col items-center pt-24 pb-24 relative overflow-hidden">
    
    <!-- Decorative Floating Assets in the body -->
    <img src="/f-cloud-light.png" alt="Cloud" class="absolute top-[20%] -right-32 w-96 opacity-50 z-0 pointer-events-none drop-shadow-xl" />
    <img src="/f-cloud-light.png" alt="Cloud" class="absolute top-[60%] -left-48 w-[500px] opacity-40 z-0 pointer-events-none drop-shadow-xl transform -scale-x-100" />
    
    <!-- Decorative Flying Doves -->
    <img src="/dove.png" alt="Dove" class="absolute top-48 left-8 w-32 md:w-48 h-auto mix-blend-color-burn opacity-70 rotate-12 pointer-events-none z-10" />
    <img src="/dove.png" alt="Dove" class="absolute top-[40%] right-8 w-40 md:w-56 h-auto mix-blend-color-burn opacity-60 -rotate-12 pointer-events-none z-10 transform scale-x-[-1]" />
    
    <div class="w-full max-w-4xl px-4 flex flex-col items-center gap-16 relative z-20">
      
      <!-- About Section -->
      <section class="w-full bg-white/60 backdrop-blur-xl rounded-[2.5rem] p-8 shadow-ethereal border border-white flex flex-col md:flex-row items-center justify-between gap-8 relative overflow-hidden">
        <div class="flex-1 text-right">
          <h3 class="text-3xl font-bold mb-2">من نحنا</h3>
          <h4 class="text-xl font-bold opacity-80 mb-4">فلسفة الصحة النفسية الأثيرية</h4>
          <p class="font-semibold text-sm leading-relaxed text-gray-800">
            الأفضل أكثر من مجرد عيادة؛ إنه ملاذ للذين يبحثون عن الأفضل. نحن نؤمن بأن الرعاية الخاصة بك تتطلب مزيجاً فريداً من الرعاية النفسية والسرية المطلقة.
          </p>
        </div>
        <div class="w-48 h-48 flex-shrink-0 bg-gradient-to-br from-white/90 to-white/40 backdrop-blur-2xl border-2 border-white rounded-[2rem] shadow-inner flex items-center justify-center p-4">
          <div class="w-32 h-32 rounded-[1.5rem] border border-ethereal-accent/20 flex flex-col items-center justify-center bg-white shadow-sm">
             <span class="font-serif text-xs font-bold tracking-widest text-ethereal-dark">AETHEREAL</span>
          </div>
        </div>
      </section>

      <!-- Why Choose Us Section -->
      <section class="w-full text-center">
        <h3 class="text-3xl font-bold mb-2 text-ethereal-dark">لماذا تختارنا؟</h3>
        <h4 class="text-xl font-semibold opacity-70 mb-10 text-ethereal-dark">6 أعمدة الثقة</h4>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6 text-right">
          <!-- Item 1 -->
          <div class="flex items-center gap-4 bg-white/50 backdrop-blur-sm p-4 rounded-2xl border border-white/60 shadow-sm hover:scale-[1.02] transition-transform">
            <div class="text-4xl font-light text-ethereal-accent opacity-50">01</div>
            <div class="flex-1">
              <h5 class="font-bold text-lg text-ethereal-dark max-w-[150px] ml-auto leading-tight">السرية المطلقة</h5>
              <p class="text-xs opacity-70 mt-1">Absolute Confidentiality</p>
            </div>
            <div class="w-10 h-10 bg-ethereal-accent rounded-xl flex items-center justify-center text-white shrink-0"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" /></svg></div>
          </div>
          <!-- More items omitted for brevity but represent structure -->
          <div class="flex items-center gap-4 bg-white/50 backdrop-blur-sm p-4 rounded-2xl border border-white/60 shadow-sm hover:scale-[1.02] transition-transform">
            <div class="text-4xl font-light text-ethereal-accent opacity-50">02</div>
            <div class="flex-1">
              <h5 class="font-bold text-lg text-ethereal-dark max-w-[150px] ml-auto leading-tight">هارلي ستريت إكسبريس</h5>
              <p class="text-xs opacity-70 mt-1">Harley Street Experts</p>
            </div>
            <div class="w-10 h-10 bg-ethereal-accent rounded-xl flex items-center justify-center text-white shrink-0"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a8 8 0 100 16 8 8 0 000-16zM8 11V7l4 2-4 2z" /></svg></div>
          </div>
          <!-- Item 3 -->
          <div class="flex items-center gap-4 bg-white/50 backdrop-blur-sm p-4 rounded-2xl border border-white/60 shadow-sm hover:scale-[1.02] transition-transform">
            <div class="text-4xl font-light text-ethereal-accent opacity-50">03</div>
            <div class="flex-1">
              <h5 class="font-bold text-lg text-ethereal-dark max-w-[150px] ml-auto leading-tight">خطط رعاية مخصصة</h5>
              <p class="text-xs opacity-70 mt-1">Bespoke Care Plans</p>
            </div>
            <div class="w-10 h-10 bg-ethereal-accent rounded-xl flex items-center justify-center text-white shrink-0"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" /><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd" /></svg></div>
          </div>
          <!-- Item 4 -->
          <div class="flex items-center gap-4 bg-white/50 backdrop-blur-sm p-4 rounded-2xl border border-white/60 shadow-sm hover:scale-[1.02] transition-transform">
            <div class="text-4xl font-light text-ethereal-accent opacity-50">04</div>
            <div class="flex-1">
              <h5 class="font-bold text-lg text-ethereal-dark max-w-[150px] ml-auto leading-tight">الوصول العالمي</h5>
              <p class="text-xs opacity-70 mt-1">Global Access</p>
            </div>
            <div class="w-10 h-10 bg-ethereal-accent rounded-xl flex items-center justify-center text-white shrink-0"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM4.332 8.027a6.012 6.012 0 011.912-2.706C6.512 5.73 6.974 6 7.5 6A1.5 1.5 0 019 7.5V8a2 2 0 004 0 2 2 0 011.523-1.943A5.977 5.977 0 0116 10c0 .34-.028.675-.083 1H15a2 2 0 00-2 2v2.197A5.973 5.973 0 0110 16v-2a2 2 0 00-2-2 2 2 0 01-2-2 2 2 0 00-1.668-1.973z" clip-rule="evenodd" /></svg></div>
          </div>
        </div>
      </section>

      <!-- Personalized Services inside Fluffy Container -->
      <section class="w-full relative mt-8 bg-white/40 bg-[url('/light_blue_fur.png')] bg-cover bg-center bg-blend-soft-light rounded-[3rem] p-10 shadow-lg border-[3px] border-ethereal-accent/20 text-center flex flex-col items-center">
        <!-- Floating Balloon element breaking out of container occasionally -->
        <img src="/f-balloon.png" alt="Balloon" class="absolute -top-16 -right-12 w-32 h-auto z-20 animate-[float_5s_ease-in-out_infinite_reverse] drop-shadow-xl pointer-events-none" />
        
        <h3 class="text-3xl font-bold mb-8 text-ethereal-dark">الخدمات الشخصية</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative z-10 w-full">
          <!-- Card 1 -->
          <div class="bg-white/80 backdrop-blur-md p-6 rounded-2xl shadow-sm hover:shadow-md border border-white text-right hover:-translate-y-1 transition-all">
             <h4 class="text-xl font-bold text-ethereal-dark mb-3 flex items-center justify-end gap-3">العلاج الفردي <div class="bg-ethereal-dark w-10 h-10 flex items-center justify-center rounded-lg text-white shrink-0"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg></div></h4>
             <p class="text-sm font-semibold opacity-90 leading-relaxed text-gray-700">دعم نفسي مخصص لك للتعامل مع التحديات التي تواجهك في حياتك بصمت.</p>
          </div>
          <!-- Card 2 -->
          <div class="bg-white/80 backdrop-blur-md p-6 rounded-2xl shadow-sm hover:shadow-md border border-white text-right hover:-translate-y-1 transition-all">
             <h4 class="text-xl font-bold text-ethereal-dark mb-3 flex items-center justify-end gap-3">التدريب التنفيذي <div class="bg-ethereal-dark w-10 h-10 flex items-center justify-center rounded-lg text-white shrink-0"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg></div></h4>
             <p class="text-sm font-semibold opacity-90 leading-relaxed text-gray-700">الدعم الشخصي والتوجيه السري لتمكينك من قيادة حياتك الشخصية والمهنية.</p>
          </div>
          <!-- Card 3 -->
          <div class="bg-white/80 backdrop-blur-md p-6 rounded-2xl shadow-sm hover:shadow-md border border-white text-right hover:-translate-y-1 transition-all">
             <h4 class="text-xl font-bold text-ethereal-dark mb-3 flex items-center justify-end gap-3">الارتقاء العاطفي <div class="bg-ethereal-dark w-10 h-10 flex items-center justify-center rounded-lg text-white shrink-0"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg></div></h4>
             <p class="text-sm font-semibold opacity-90 leading-relaxed text-gray-700">الرحلة للتحسن المستمر لتعزيز النمو العاطفي والنفسي وإطلاق طاقاتك.</p>
          </div>
          <!-- Card 4 -->
          <div class="bg-white/80 backdrop-blur-md p-6 rounded-2xl shadow-sm hover:shadow-md border border-white text-right hover:-translate-y-1 transition-all">
             <h4 class="text-xl font-bold text-ethereal-dark mb-3 flex items-center justify-end gap-3">إدارة القلق والتوتر <div class="bg-ethereal-dark w-10 h-10 flex items-center justify-center rounded-lg text-white shrink-0"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div></h4>
             <p class="text-sm font-semibold opacity-90 leading-relaxed text-gray-700">تقنيات فعالة للتخفيف من تأثير التوتر في حياتك اليومية.</p>
          </div>
        </div>
      </section>

      <!-- FAQ Section -->
      <section class="w-full mt-8 text-center">
        <h3 class="text-3xl font-bold mb-8 text-ethereal-dark">الأسئلة الشائعة</h3>
        <div class="space-y-4 max-w-3xl mx-auto">
          <details class="group bg-white/50 backdrop-blur-lg rounded-2xl border border-white shadow-sm overflow-hidden text-right transition-all">
            <summary class="p-5 font-bold text-lg cursor-pointer hover:bg-white/70 transition-colors list-none flex justify-between items-center text-ethereal-dark">
              <span class="text-ethereal-accent text-xl font-normal group-open:-rotate-45 transition-transform origin-center">+</span>
              <span>س1: متى أو كيف يمكنني حجز موعد؟</span>
            </summary>
            <div class="p-5 pt-0 text-sm font-semibold border-t border-white/50 mt-2 text-gray-800">
              يمكنك حجز موعد عبر موقعنا أو التواصل معنا بشكل مباشر لنرتب لك جلسة استشارية أولية في الوقت الأنسب لك.
            </div>
          </details>
          <details class="group bg-white/50 backdrop-blur-lg rounded-2xl border border-white shadow-sm overflow-hidden text-right transition-all">
            <summary class="p-5 font-bold text-lg cursor-pointer hover:bg-white/70 transition-colors list-none flex justify-between items-center text-ethereal-dark">
              <span class="text-ethereal-accent text-xl font-normal group-open:-rotate-45 transition-transform origin-center">+</span>
              <span>س2: هل الدعم متاح دولياً؟</span>
            </summary>
            <div class="p-5 pt-0 text-sm font-semibold border-t border-white/50 mt-2 text-gray-800">
              نعم، نقدم استشارات شاملة للعملاء حول العالم أينما كنت باستخدام أحدث تقنيات الاتصال الآمنة.
            </div>
          </details>
          <!-- Additional abbreviated FAQ items matching stylistic tone -->
        </div>
      </section>

      <!-- Map & Contact -->
      <section class="w-full mt-8 text-center">
        <h3 class="text-3xl font-bold mb-8 text-ethereal-dark">قسم الاتصال والهامش</h3>
        
        <div class="bg-white/60 backdrop-blur-xl rounded-[2.5rem] p-8 border border-white shadow-ethereal flex flex-col md:flex-row gap-8 items-center text-right">
          
          <div class="w-full md:w-1/2 flex flex-col gap-6">
             <div>
               <h4 class="text-3xl font-bold text-ethereal-dark mb-2">تواصل معنا</h4>
               <p class="font-bold text-sm opacity-80 text-ethereal-dark">حجز رعاية التميز في الصحة النفسية</p>
             </div>
             
             <div class="space-y-4 text-sm font-bold mt-4">
               <p class="flex items-center gap-3 justify-end text-lg"><span class="opacity-90">شلر مايا، لندن</span> <svg class="w-6 h-6 text-ethereal-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg></p>
               <p class="flex items-center gap-3 justify-end text-lg"><span class="opacity-90">contact@aethereal.com</span> <svg class="w-6 h-6 text-ethereal-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg></p>
               <p class="flex items-center gap-3 justify-end text-lg"><span class="opacity-90">واتساب</span> <svg class="w-6 h-6 text-ethereal-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg></p>
             </div>
          </div>

          <div class="w-full md:w-1/2 h-64 bg-ethereal-light rounded-[2rem] overflow-hidden shadow-inner border-[3px] border-white relative">
             <img src="https://static-maps.yandex.ru/1.x/?ll=-0.1276,51.5074&size=600,300&z=13&l=map&lang=en_US" alt="London Map" class="w-full h-full object-cover mix-blend-multiply opacity-80" />
             <div class="absolute inset-0 bg-ethereal-light/20 mix-blend-overlay"></div>
          </div>
          
        </div>
      </section>

    </div>
  </div>
</Layout>com</span> <svg class="w-6 h-6 text-ethereal-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg></p>
             <p class="flex items-center gap-3 justify-end text-lg"><span class="opacity-90">واتساب</span> <svg class="w-6 h-6 text-ethereal-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg></p>
           </div>
        </div>

        <div class="w-full md:w-1/2 h-64 bg-ethereal-light rounded-[2rem] overflow-hidden shadow-inner border-[3px] border-white relative">
           <img src="https://static-maps.yandex.ru/1.x/?ll=-0.1276,51.5074&size=600,300&z=13&l=map&lang=en_US" alt="London Map" class="w-full h-full object-cover mix-blend-multiply opacity-80" />
           <!-- Simple Map Overlay -->
           <div class="absolute inset-0 bg-blue-200/20 mix-blend-overlay"></div>
        </div>
        
      </div>
    </section>

  </div>
</Layout>
