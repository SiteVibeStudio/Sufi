---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AETHEREAL | الصحة النفسية" description="رفع مستوى التميز الذهني في لندن.">
  
  <!-- Hero Section with Custom Background -->
  <section class="w-full relative flex flex-col items-center pt-8 pb-32 text-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/hero_sky.png" alt="Ethereal Sky" class="w-full h-full object-cover object-bottom" />
      <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-t from-ethereal-light to-transparent"></div>
    </div>
    
    <div class="relative z-10 w-full max-w-4xl px-4 flex flex-col items-center">
      <h1 class="font-serif text-3xl tracking-[0.2em] text-ethereal-dark mb-16 opacity-80 mix-blend-color-burn">AETHEREAL</h1>
      
      <div class="bg-white/20 backdrop-blur-md rounded-3xl p-8 mb-8 border border-white/40 shadow-ethereal max-w-2xl">
        <h2 class="text-4xl md:text-5xl font-extrabold text-ethereal-dark mb-4 leading-tight">
          رفع مستوى التميز الذهني في لندن.
        </h2>
        <p class="text-lg md:text-xl font-semibold text-ethereal-dark opacity-90 max-w-lg mx-auto">
          طريقتك الشخصي والتحويلي نحو المرونة يبدأ من علاج قليل من الدعم النفسي المتميزون المغتربون.
        </p>
      </div>
      
      <button class="px-8 py-3 bg-ethereal-dark hover:bg-ethereal-accent text-white font-bold rounded-full transition-all duration-300 shadow-xl shadow-ethereal-dark/40 transform hover:-translate-y-1">
        حجز استشارة خاصة
      </button>
    </div>
  </section>

  <div class="w-full max-w-4xl px-4 flex flex-col items-center gap-16 relative z-20 -mt-10 pb-24">
    
    <!-- Decorative Flying Doves -->
    <img src="/dove.png" alt="" class="absolute top-48 -left-12 w-48 h-auto mix-blend-screen opacity-70 rotate-12 pointer-events-none" />
    <img src="/dove.png" alt="" class="absolute top-[40%] -right-16 w-56 h-auto mix-blend-screen opacity-60 -rotate-12 pointer-events-none" />
    <img src="/dove.png" alt="" class="absolute bottom-64 -left-8 w-40 h-auto mix-blend-screen opacity-50 rotate-6 pointer-events-none transform scale-x-[-1]" />
    
    <!-- About Section -->
    <section class="w-full bg-white/50 backdrop-blur-lg rounded-3xl p-8 shadow-ethereal border border-white flex flex-col md:flex-row items-center justify-between gap-8 relative overflow-hidden">
      <div class="flex-1 text-right">
        <h3 class="text-3xl font-bold mb-2">من نحنا</h3>
        <h4 class="text-xl font-bold opacity-80 mb-4">فلسفة الصحة النفسية الأثيرية</h4>
        <p class="font-semibold text-sm leading-relaxed">
          الأفضل أكثر من مجرد عيادة؛ إنه ملاذ للذين يبحثون عن الأفضل. نحن نؤمن بأن الرعاية الخاصة بك تتطلب مزيجاً فريداً من الرعاية النفسية والسرية المطلقة.
        </p>
      </div>
      <div class="w-48 h-48 flex-shrink-0 bg-gradient-to-br from-white/80 to-white/30 backdrop-blur-xl border-2 border-white rounded-3xl shadow-inner flex items-center justify-center p-4">
        <div class="w-32 h-32 rounded-full border border-ethereal-accent/20 flex flex-col items-center justify-center bg-white shadow-sm">
           <svg class="w-8 h-8 text-ethereal-dark mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z" /></svg>
           <span class="font-serif text-xs font-bold tracking-widest text-ethereal-dark">AETHEREAL</span>
        </div>
      </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="w-full text-center">
      <h3 class="text-3xl font-bold mb-2">لماذا تختارنا؟</h3>
      <h4 class="text-xl font-semibold opacity-70 mb-10">6 أعمدة الثقة</h4>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8 text-right">
        <!-- Item 1 -->
        <div class="flex items-center gap-4 bg-white/40 p-4 rounded-xl border border-white/50 shadow-sm hover:scale-[1.02] transition-transform">
          <div class="text-4xl font-light text-ethereal-accent">01</div>
          <div class="flex-1">
            <h5 class="font-bold text-lg">السرية المطلقة</h5>
            <p class="text-xs opacity-80">Absolute Confidentiality</p>
          </div>
          <div class="w-10 h-10 bg-ethereal-dark rounded-lg flex items-center justify-center text-white"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" /></svg></div>
        </div>
        <!-- Item 2 -->
        <div class="flex items-center gap-4 bg-white/40 p-4 rounded-xl border border-white/50 shadow-sm hover:scale-[1.02] transition-transform">
          <div class="text-4xl font-light text-ethereal-accent">02</div>
          <div class="flex-1">
            <h5 class="font-bold text-lg">هارلي ستريت إكسبريس</h5>
            <p class="text-xs opacity-80">Harley Street Experts</p>
          </div>
          <div class="w-10 h-10 bg-ethereal-dark rounded-lg flex items-center justify-center text-white"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a8 8 0 100 16 8 8 0 000-16zM8 11V7l4 2-4 2z" /></svg></div>
        </div>
        <!-- Item 3 -->
        <div class="flex items-center gap-4 bg-white/40 p-4 rounded-xl border border-white/50 shadow-sm hover:scale-[1.02] transition-transform">
          <div class="text-4xl font-light text-ethereal-accent">03</div>
          <div class="flex-1">
            <h5 class="font-bold text-lg">خطط رعاية مخصصة</h5>
            <p class="text-xs opacity-80">Bespoke Care Plans</p>
          </div>
          <div class="w-10 h-10 bg-ethereal-dark rounded-lg flex items-center justify-center text-white"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" /><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd" /></svg></div>
        </div>
        <!-- Item 4 -->
        <div class="flex items-center gap-4 bg-white/40 p-4 rounded-xl border border-white/50 shadow-sm hover:scale-[1.02] transition-transform">
          <div class="text-4xl font-light text-ethereal-accent">04</div>
          <div class="flex-1">
            <h5 class="font-bold text-lg">الوصول العالمي</h5>
            <p class="text-xs opacity-80">Global Access</p>
          </div>
          <div class="w-10 h-10 bg-ethereal-dark rounded-lg flex items-center justify-center text-white"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM4.332 8.027a6.012 6.012 0 011.912-2.706C6.512 5.73 6.974 6 7.5 6A1.5 1.5 0 019 7.5V8a2 2 0 004 0 2 2 0 011.523-1.943A5.977 5.977 0 0116 10c0 .34-.028.675-.083 1H15a2 2 0 00-2 2v2.197A5.973 5.973 0 0110 16v-2a2 2 0 00-2-2 2 2 0 01-2-2 2 2 0 00-1.668-1.973z" clip-rule="evenodd" /></svg></div>
        </div>
        <!-- Item 5 -->
        <div class="flex items-center gap-4 bg-white/40 p-4 rounded-xl border border-white/50 shadow-sm hover:scale-[1.02] transition-transform">
          <div class="text-4xl font-light text-ethereal-accent">05</div>
          <div class="flex-1">
            <h5 class="font-bold text-lg">الممارسة المبنية على الأدلة</h5>
            <p class="text-xs opacity-80">Evidence Based Practice</p>
          </div>
          <div class="w-10 h-10 bg-ethereal-dark rounded-lg flex items-center justify-center text-white"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z" /></svg></div>
        </div>
        <!-- Item 6 -->
        <div class="flex items-center gap-4 bg-white/40 p-4 rounded-xl border border-white/50 shadow-sm hover:scale-[1.02] transition-transform">
          <div class="text-4xl font-light text-ethereal-accent">06</div>
          <div class="flex-1">
            <h5 class="font-bold text-lg">بيئة فاخرة</h5>
            <p class="text-xs opacity-80">Luxurious Environment</p>
          </div>
          <div class="w-10 h-10 bg-ethereal-dark rounded-lg flex items-center justify-center text-white"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg></div>
        </div>
      </div>
    </section>

    <!-- Personalized Services inside Fluffy Container -->
    <section class="w-full relative mt-12 bg-white/30 bg-[url('/light_blue_fur.png')] bg-cover bg-center rounded-[3rem] p-10 shadow-xl border-[4px] border-dashed border-ethereal-accent/60 text-center">
      <h3 class="text-3xl font-bold mb-8 text-ethereal-dark">الخدمات الشخصية</h3>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative z-10">
        <!-- Card 1 -->
        <div class="bg-white/80 backdrop-blur-sm p-6 rounded-2xl shadow-sm border border-white text-right hover:scale-[1.02] transition-transform">
           <h4 class="text-xl font-bold text-ethereal-dark mb-3 flex items-center justify-end gap-3">العلاج الفردي <div class="bg-ethereal-dark w-10 h-10 flex items-center justify-center rounded-lg text-white shrink-0"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg></div></h4>
           <p class="text-sm font-semibold opacity-90 leading-relaxed">دعم نفسي مخصص لك للتعامل مع التحديات التي تواجهك في حياتك بصمت.</p>
        </div>
        <!-- Card 2 -->
        <div class="bg-white/80 backdrop-blur-sm p-6 rounded-2xl shadow-sm border border-white text-right hover:scale-[1.02] transition-transform">
           <h4 class="text-xl font-bold text-ethereal-dark mb-3 flex items-center justify-end gap-3">التدريب التنفيذي <div class="bg-ethereal-dark w-10 h-10 flex items-center justify-center rounded-lg text-white shrink-0"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg></div></h4>
           <p class="text-sm font-semibold opacity-90 leading-relaxed">الدعم الشخصي والتوجيه السري لتمكينك من قيادة حياتك الشخصية والمهنية.</p>
        </div>
        <!-- Card 3 -->
        <div class="bg-white/80 backdrop-blur-sm p-6 rounded-2xl shadow-sm border border-white text-right hover:scale-[1.02] transition-transform">
           <h4 class="text-xl font-bold text-ethereal-dark mb-3 flex items-center justify-end gap-3">الارتقاء العاطفي <div class="bg-ethereal-dark w-10 h-10 flex items-center justify-center rounded-lg text-white shrink-0"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg></div></h4>
           <p class="text-sm font-semibold opacity-90 leading-relaxed">الرحلة للتحسن المستمر لتعزيز النمو العاطفي والنفسي وإطلاق طاقاتك.</p>
        </div>
        <!-- Card 4 -->
        <div class="bg-white/80 backdrop-blur-sm p-6 rounded-2xl shadow-sm border border-white text-right hover:scale-[1.02] transition-transform">
           <h4 class="text-xl font-bold text-ethereal-dark mb-3 flex items-center justify-end gap-3">إدارة القلق والتوتر <div class="bg-ethereal-dark w-10 h-10 flex items-center justify-center rounded-lg text-white shrink-0"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div></h4>
           <p class="text-sm font-semibold opacity-90 leading-relaxed">تقنيات فعالة للتخفيف من تأثير التوتر في حياتك اليومية.</p>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="w-full mt-12 text-center">
      <h3 class="text-3xl font-bold mb-8">الأسئلة الشائعة</h3>
      <div class="space-y-4 max-w-3xl mx-auto">
        <details class="group bg-white/60 backdrop-blur-md rounded-2xl border border-white shadow-sm overflow-hidden text-right transition-all">
          <summary class="p-5 font-bold text-lg cursor-pointer hover:bg-white/20 transition-colors list-none flex justify-between items-center">
            <span class="text-ethereal-accent text-xl font-normal group-open:-rotate-45 transition-transform origin-center">+</span>
            <span>س1: متى أو كيف يمكنني حجز موعد؟</span>
          </summary>
          <div class="p-5 pt-0 text-sm font-semibold border-t border-white/50 mt-2 text-gray-700">
            يمكنك حجز موعد عبر موقعنا أو التواصل معنا بشكل مباشر لنرتب لك جلسة استشارية أولية في الوقت الأنسب لك.
          </div>
        </details>
        <details class="group bg-white/60 backdrop-blur-md rounded-2xl border border-white shadow-sm overflow-hidden text-right transition-all">
          <summary class="p-5 font-bold text-lg cursor-pointer hover:bg-white/20 transition-colors list-none flex justify-between items-center">
            <span class="text-ethereal-accent text-xl font-normal group-open:-rotate-45 transition-transform origin-center">+</span>
            <span>س2: هل الدعم متاح دولياً؟</span>
          </summary>
          <div class="p-5 pt-0 text-sm font-semibold border-t border-white/50 mt-2 text-gray-700">
            نعم، نقدم استشارات شاملة للعملاء حول العالم أينما كنت باستخدام أحدث تقنيات الاتصال الآمنة.
          </div>
        </details>
        <details class="group bg-white/60 backdrop-blur-md rounded-2xl border border-white shadow-sm overflow-hidden text-right transition-all">
          <summary class="p-5 font-bold text-lg cursor-pointer hover:bg-white/20 transition-colors list-none flex justify-between items-center">
            <span class="text-ethereal-accent text-xl font-normal group-open:-rotate-45 transition-transform origin-center">+</span>
            <span>س3: ماذا يحدث في الاستشارة الأولى (التقييم)؟</span>
          </summary>
          <div class="p-5 pt-0 text-sm font-semibold border-t border-white/50 mt-2 text-gray-700">
            يتم تقييم حالتك بكل سرية من قبل خبرائنا لتحديد الخطة المناسبة والتعرف على التحديات التي تواجهك وكيفية التعامل معها.
          </div>
        </details>
        <details class="group bg-white/60 backdrop-blur-md rounded-2xl border border-white shadow-sm overflow-hidden text-right transition-all">
          <summary class="p-5 font-bold text-lg cursor-pointer hover:bg-white/20 transition-colors list-none flex justify-between items-center">
            <span class="text-ethereal-accent text-xl font-normal group-open:-rotate-45 transition-transform origin-center">+</span>
            <span>س4: من الجدير بالثقة؟ (احترام طبي لبياناتي)</span>
          </summary>
          <div class="p-5 pt-0 text-sm font-semibold border-t border-white/50 mt-2 text-gray-700">
            نحن نلتزم بأعلى معايير السرية المطلقة لضمان حماية بياناتكم ومعلوماتكم الشخصية بشكل كامل.
          </div>
        </details>
      </div>
    </section>

    <!-- Map & Contact -->
    <section class="w-full mt-12 text-center">
      <h3 class="text-3xl font-bold mb-8">قسم الاتصال والهامش</h3>
      
      <div class="bg-white/70 backdrop-blur-md rounded-[2.5rem] p-8 border border-white shadow-ethereal flex flex-col md:flex-row gap-12 items-center text-right">
        
        <div class="w-full md:w-1/2 flex flex-col gap-6">
           <div>
             <h4 class="text-3xl font-bold text-ethereal-dark mb-2">تواصل معنا</h4>
             <p class="font-bold text-sm opacity-80">حجز رعاية التميز في الصحة النفسية</p>
           </div>
           
           <div class="space-y-4 text-sm font-bold mt-4">
             <p class="flex items-center gap-3 justify-end text-lg"><span class="opacity-90">شلر مايا، لندن</span> <svg class="w-6 h-6 text-ethereal-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg></p>
             <p class="flex items-center gap-3 justify-end text-lg"><span class="opacity-90">contact@aethereal.com</span> <svg class="w-6 h-6 text-ethereal-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg></p>
             <p class="flex items-center gap-3 justify-end text-lg"><span class="opacity-90">واتساب</span> <svg class="w-6 h-6 text-ethereal-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg></p>
           </div>
        </div>

        <div class="w-full md:w-1/2 h-64 bg-ethereal-light rounded-[2rem] overflow-hidden shadow-inner border-[3px] border-white relative">
           <img src="https://static-maps.yandex.ru/1.x/?ll=-0.1276,51.5074&size=600,300&z=13&l=map&lang=en_US" alt="London Map" class="w-full h-full object-cover mix-blend-multiply opacity-80" />
           <!-- Simple Map Overlay -->
           <div class="absolute inset-0 bg-blue-200/20 mix-blend-overlay"></div>
        </div>
        
      </div>
    </section>

  </div>
</Layout>
